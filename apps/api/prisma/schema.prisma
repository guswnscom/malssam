generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String       @id @default(uuid()) @db.Uuid
  email           String       @unique @db.VarChar(255)
  name            String       @db.VarChar(100)
  passwordHash    String?      @map("password_hash") @db.VarChar(255)
  authProvider    String       @default("email") @map("auth_provider") @db.VarChar(20)
  authProviderId  String?      @map("auth_provider_id") @db.VarChar(255)
  status          String       @default("active") @db.VarChar(20)
  lastLoginAt     DateTime?    @map("last_login_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  memberships     Membership[]
  sermonRequests  SermonRequest[]
  prayerTopics    PrayerTopic[]
  @@map("users")
}

model Church {
  id                  String             @id @default(uuid()) @db.Uuid
  name                String             @db.VarChar(100)
  denomination        String             @default("대한예수교장로회") @db.VarChar(50)
  sizeCategory        String             @map("size_category") @db.VarChar(20)
  inviteCode          String             @unique @map("invite_code") @db.VarChar(20)
  inviteCodeExpiresAt DateTime?          @map("invite_code_expires_at")
  status              String             @default("active") @db.VarChar(20)
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  profile             ChurchProfile?
  subscription        Subscription?
  memberships         Membership[]
  worshipSchedules    WorshipSchedule[]
  sermonRequests      SermonRequest[]
  prayerTopics        PrayerTopic[]
  @@map("churches")
}

model ChurchProfile {
  id                String   @id @default(uuid()) @db.Uuid
  churchId          String   @unique @map("church_id") @db.Uuid
  sermonStyle       String   @default("BALANCED") @map("sermon_style") @db.VarChar(20)
  congregationType  String   @default("ADULT") @map("congregation_type") @db.VarChar(20)
  worshipTypes      String[] @default(["SUNDAY"]) @map("worship_types")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  church            Church   @relation(fields: [churchId], references: [id])
  @@map("church_profiles")
}

model Membership {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  churchId  String   @map("church_id") @db.Uuid
  role      String   @db.VarChar(20)
  status    String   @default("active") @db.VarChar(20)
  joinedAt  DateTime @default(now()) @map("joined_at")
  user      User     @relation(fields: [userId], references: [id])
  church    Church   @relation(fields: [churchId], references: [id])
  @@unique([userId, churchId])
  @@map("memberships")
}

model WorshipSchedule {
  id        String   @id @default(uuid()) @db.Uuid
  churchId  String   @map("church_id") @db.Uuid
  type      String   @db.VarChar(20)
  name      String   @db.VarChar(50)
  dayOfWeek Int?     @map("day_of_week")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  church    Church   @relation(fields: [churchId], references: [id])
  @@map("worship_schedules")
}

model SermonRequest {
  id                  String       @id @default(uuid()) @db.Uuid
  churchId            String       @map("church_id") @db.Uuid
  userId              String       @map("user_id") @db.Uuid
  worshipType         String       @map("worship_type") @db.VarChar(20)
  targetDate          DateTime     @map("target_date") @db.Date
  scripture           String       @db.VarChar(100)
  depth               String       @default("MODERATE") @db.VarChar(10)
  targetAudience      String       @default("ALL") @map("target_audience") @db.VarChar(10)
  specialInstruction  String?      @map("special_instruction") @db.Text
  status              String       @default("generating") @db.VarChar(20)
  aiModel             String?      @map("ai_model") @db.VarChar(50)
  aiTokensUsed        Int?         @map("ai_tokens_used")
  createdAt           DateTime     @default(now()) @map("created_at")
  church              Church       @relation(fields: [churchId], references: [id])
  user                User         @relation(fields: [userId], references: [id])
  draft               SermonDraft?
  @@index([churchId, targetDate(sort: Desc)])
  @@index([userId])
  @@map("sermon_requests")
}

model SermonDraft {
  id                String        @id @default(uuid()) @db.Uuid
  sermonRequestId   String        @unique @map("sermon_request_id") @db.Uuid
  title             String        @db.VarChar(200)
  scripture         String        @db.VarChar(100)
  scriptureText     String?       @map("scripture_text") @db.Text
  summary           String        @db.Text
  introduction      String        @db.Text
  outline           Json
  application       String        @db.Text
  conclusion        String        @db.Text
  regenerationCount Int           @default(0) @map("regeneration_count")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  sermonRequest     SermonRequest @relation(fields: [sermonRequestId], references: [id])
  citations         Citation[]
  @@map("sermon_drafts")
}

model Citation {
  id             String      @id @default(uuid()) @db.Uuid
  sermonDraftId  String      @map("sermon_draft_id") @db.Uuid
  citationType   String      @map("citation_type") @db.VarChar(20)
  sourceAuthor   String?     @map("source_author") @db.VarChar(100)
  sourceTitle    String?     @map("source_title") @db.VarChar(200)
  sourceInfo     String?     @map("source_info") @db.VarChar(500)
  createdAt      DateTime    @default(now()) @map("created_at")
  sermonDraft    SermonDraft @relation(fields: [sermonDraftId], references: [id])
  @@index([sermonDraftId])
  @@map("citations")
}

model PrayerTopic {
  id        String   @id @default(uuid()) @db.Uuid
  churchId  String   @map("church_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String   @db.VarChar(100)
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  church    Church   @relation(fields: [churchId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  @@index([churchId, createdAt(sort: Desc)])
  @@map("prayer_topics")
}

model Subscription {
  id                String    @id @default(uuid()) @db.Uuid
  churchId          String    @unique @map("church_id") @db.Uuid
  plan              String    @default("SEED") @db.VarChar(10)
  status            String    @default("trial") @db.VarChar(20)
  trialStart        DateTime  @map("trial_start") @db.Date
  trialEnd          DateTime  @map("trial_end") @db.Date
  billingStart      DateTime? @map("billing_start") @db.Date
  monthlyPrice      Int?      @map("monthly_price")
  maxPastors        Int       @default(3) @map("max_pastors")
  maxSermonsMonth   Int       @default(20) @map("max_sermons_month")
  pgBillingKey      String?   @map("pg_billing_key") @db.VarChar(255)
  cardLastFour      String?   @map("card_last_four") @db.VarChar(4)
  cardBrand         String?   @map("card_brand") @db.VarChar(20)
  nextBillingDate   DateTime? @map("next_billing_date") @db.Date
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  church            Church    @relation(fields: [churchId], references: [id])
  @@map("subscriptions")
}
